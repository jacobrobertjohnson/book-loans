@model BookFormViewModel
@{
    ViewData["Title"] = "Edit BookEntity";
}

<h1>Edit BookEntity</h1>

@if (TempData["EditBookError"] is string editBookError)
{
    <p>@editBookError</p>
}

<form asp-action="EditBook" asp-route-id="@Model.Id" method="post">
    @Html.AntiForgeryToken()
    <div asp-validation-summary="ModelOnly"></div>

    <div>
        <label asp-for="Title"></label>
        <input asp-for="Title" />
        <span asp-validation-for="Title"></span>
    </div>

    <div>
        <label asp-for="SelectedAuthorIds">Existing Authors</label>
        <select asp-for="SelectedAuthorIds" asp-items="@(new Microsoft.AspNetCore.Mvc.Rendering.MultiSelectList(Model.Authors, nameof(AuthorViewModel.Id), nameof(AuthorViewModel.Name), Model.SelectedAuthorIds))" multiple size="8">
        </select>
        <button type="button" onclick="clearSelectedAuthors(this)">Clear selected authors</button>
        <span asp-validation-for="SelectedAuthorIds"></span>
    </div>

    <div>
        <label asp-for="NewAuthorNames">Or Create New AuthorEntity(s)</label>
        <textarea asp-for="NewAuthorNames" rows="5"></textarea>
        <small>Enter one author name per line.</small>
        <span asp-validation-for="NewAuthorNames"></span>
    </div>

    <div>
        <label asp-for="Edition"></label>
        <input asp-for="Edition" />
        <span asp-validation-for="Edition"></span>
    </div>

    <div>
        <label asp-for="YearFirstPublished"></label>
        <input asp-for="YearFirstPublished" />
        <span asp-validation-for="YearFirstPublished"></span>
    </div>

    <div>
        <label asp-for="YearEditionPublished"></label>
        <input asp-for="YearEditionPublished" />
        <span asp-validation-for="YearEditionPublished"></span>
    </div>

    <div>
        <label asp-for="Isbn">ISBN (optional)</label>
        <input asp-for="Isbn" />
        <span asp-validation-for="Isbn"></span>
    </div>

    <div>
        <label asp-for="DateOfPurchase"></label>
        <input asp-for="DateOfPurchase" />
        <span asp-validation-for="DateOfPurchase"></span>
    </div>

    <div>
        <label asp-for="LocationOfPurchase"></label>
        <input asp-for="LocationOfPurchase" />
        <span asp-validation-for="LocationOfPurchase"></span>
    </div>

    <div>
        <label asp-for="ConditionId"></label>
        <select asp-for="ConditionId" asp-items="@(new SelectList(Model.Conditions, nameof(ConditionViewModel.Id), nameof(ConditionViewModel.Name)))"></select>
        <span asp-validation-for="ConditionId"></span>
    </div>

    <button type="submit">Save Changes</button>
</form>

<h2>Photos</h2>

<form asp-action="UploadBookPhoto" asp-route-id="@Model.Id" method="post" enctype="multipart/form-data">
    @Html.AntiForgeryToken()
    <div>
        <label for="photoFile">Upload New Photo</label>
        <input type="file" id="photoFile" name="photoFile" accept="image/*" />
    </div>
    <div>
        <label for="caption">Caption (optional)</label>
        <input type="text" id="caption" name="caption" maxlength="500" />
    </div>
    <button type="submit">Upload Photo</button>
</form>

@if (Model.BookPhotos.Count == 0)
{
    <p>No photos uploaded yet.</p>
}
else
{
    <ul style="list-style:none; padding-left:0; display:flex; flex-wrap:wrap; gap:16px;">
    @foreach (BookPhotoItemViewModel photo in Model.BookPhotos)
    {
        <li style="border:1px solid #ccc; padding:8px; width:170px;">
            <img
                src="@Url.Action("BookPhotoEntity", "Admin", new { id = photo.Id })"
                alt="BookEntity photo"
                style="display:block; width:150px; height:150px; object-fit:cover;" />
            @if (photo.IsDefault)
            {
                <p style="margin:8px 0 4px 0;"><strong>Default Image</strong></p>
            }
            <p style="margin:8px 0 4px 0;">@(string.IsNullOrWhiteSpace(photo.Caption) ? "(no caption)" : photo.Caption)</p>
            <p style="margin:0 0 8px 0;">@photo.UploadedAtUtc.ToString("u")</p>
            @if (!photo.IsDefault)
            {
                <form asp-action="SetDefaultBookPhoto" asp-route-id="@Model.Id" asp-route-photoId="@photo.Id" method="post" style="margin-bottom:8px;">
                    @Html.AntiForgeryToken()
                    <button type="submit">Set As Default</button>
                </form>
            }
            <form asp-action="DeleteBookPhoto" asp-route-id="@Model.Id" asp-route-photoId="@photo.Id" method="post">
                @Html.AntiForgeryToken()
                <button type="submit">Delete</button>
            </form>
        </li>
    }
    </ul>
}

<h2>Checkout Status</h2>

<p>
    <a asp-action="CreateCheckout" asp-route-bookId="@Model.Id">Add Checkout</a>
</p>

@if (Model.CurrentCheckout is null)
{
    <p>This book is currently available.</p>
}
else
{
    <p>
        Checked out by
        <a asp-action="EditBorrower" asp-route-id="@Model.CurrentCheckout.BorrowerId">@Model.CurrentCheckout.BorrowerFullName</a>
        on @Model.CurrentCheckout.CheckedOutAtUtc.ToString("u").
    </p>
    <form asp-action="ReturnCheckout" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" name="loanId" value="@Model.CurrentCheckout.Id" />
        <input type="hidden" name="returnTo" value="EditBook" />
        <input type="hidden" name="sourceId" value="@Model.Id" />
        <button type="submit">Mark Returned</button>
    </form>
}

<h2>Checkout History</h2>

@if (Model.CheckoutHistory.Count == 0)
{
    <p>No checkout history for this book yet.</p>
}
else
{
    <table>
        <thead>
            <tr>
                <th>BorrowerEntity</th>
                <th>Checked Out</th>
                <th>Returned</th>
            </tr>
        </thead>
        <tbody>
        @foreach (BookLoanViewModel checkout in Model.CheckoutHistory)
        {
            <tr>
                <td>
                    <a asp-action="EditBorrower" asp-route-id="@checkout.BorrowerId">@checkout.BorrowerFullName</a>
                </td>
                <td>@checkout.CheckedOutAtUtc.ToString("u")</td>
                <td>@(checkout.ReturnedAtUtc?.ToString("u") ?? "(active)")</td>
            </tr>
        }
        </tbody>
    </table>
}

<p>
    <a asp-action="Books">Back to Books</a>
</p>

<script>
    function clearSelectedAuthors(button) {
        const selectElement = button.parentElement.querySelector('select[multiple]');
        if (!selectElement) {
            return;
        }

        for (const option of selectElement.options) {
            option.selected = false;
        }
    }
</script>
