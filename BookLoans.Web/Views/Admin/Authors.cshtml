@model AuthorsIndexViewModel
@{
    ViewData["Title"] = "Manage Authors";
}

@if (TempData["AuthorsError"] is string authorsError)
{
    <p class="message-error">@authorsError</p>
}

@if (Model.Authors.Count == 0)
{
    <div class="card"><p class="muted">No authors have been added yet.</p></div>
}
else
{
    <div class="card table-wrap">
        <div class="card-header">
            <h1 class="page-title">Manage Authors</h1>
            <a class="button button-primary" asp-action="CreateAuthor">Add Author</a>
        </div>
    <table>
        <thead>
            <tr>
                <th>Name</th>
                <th>Books</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
        @foreach (AuthorViewModel author in Model.Authors)
        {
            <tr>
                <td><a asp-action="EditAuthor" asp-route-id="@author.Id">@author.Name</a></td>
                <td>@author.BookCount</td>
                <td>
                    <form asp-action="DeleteAuthor" asp-route-id="@author.Id" method="post" class="inline">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="button-danger">Delete</button>
                    </form>
                </td>
            </tr>
        }
        </tbody>
    </table>
    </div>
}
