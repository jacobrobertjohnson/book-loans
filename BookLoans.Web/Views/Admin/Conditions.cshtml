@model ConditionsIndexViewModel
@{
    ViewData["Title"] = "Manage Conditions";
}

@if (TempData["ConditionsError"] is string conditionsError)
{
    <p class="message-error">@conditionsError</p>
}

@if (Model.Conditions.Count == 0)
{
    <div class="card"><p class="muted">No conditions have been added yet.</p></div>
}
else
{
    <div class="card table-wrap">
        <div class="card-header">
            <h1 class="page-title">Manage Conditions</h1>
            <a class="button button-primary" asp-action="CreateCondition">Add Condition</a>
        </div>
    <table>
        <thead>
            <tr>
                <th>Name</th>
                <th>Books</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
        @foreach (ConditionViewModel condition in Model.Conditions)
        {
            <tr>
                <td><a asp-action="EditCondition" asp-route-id="@condition.Id">@condition.Name</a></td>
                <td>@condition.BookCount</td>
                <td>
                    <form asp-action="DeleteCondition" asp-route-id="@condition.Id" method="post" class="inline">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="button-danger">Delete</button>
                    </form>
                </td>
            </tr>
        }
        </tbody>
    </table>
    </div>
}
