@model AuthorFormViewModel
@{
    ViewData["Title"] = "Edit Author";
}

<div class="page-title-row">
    <a class="back-arrow" asp-action="Authors" title="Back to Manage Authors">&#8592;</a>
    <h1 class="page-title">Edit Author</h1>
</div>

<form asp-action="EditAuthor" asp-route-id="@Model.Id" method="post" class="form-shell stack">
    @Html.AntiForgeryToken()
    <div asp-validation-summary="ModelOnly" class="message-error"></div>

    <h2>Author Details</h2>

    <div class="field">
        <label asp-for="Name"></label>
        <input asp-for="Name" />
        <span asp-validation-for="Name"></span>
    </div>

    <div class="actions-row">
        <button type="submit" class="button-primary">Save Changes</button>
    </div>
</form>
