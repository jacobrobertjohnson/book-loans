@model HomepageViewModel
@{
    ViewData["Title"] = "Checked Out Books";
}

<h1>Currently Checked Out Books</h1>

@if (Model.BorrowerGroups.Count == 0)
{
    <p>No books are currently checked out.</p>
}
else
{
    @foreach (BorrowerCheckoutGroupViewModel borrowerGroup in Model.BorrowerGroups)
    {
        <section>
            <h2>@borrowerGroup.BorrowerFullName</h2>
            <ul>
                @foreach (BookLoanViewModel book in borrowerGroup.Books)
                {
                    <li>
                        <img
                            src="@Url.Action("BookDefaultPhoto", "Admin", new { id = book.BookId })"
                            alt="Book cover"
                            class="media-thumb"
                            onerror="this.onerror=null;this.src='@Url.Content("~/images/book-fallback.svg")';" />
                        <strong>@book.BookTitle</strong> by @book.BookAuthorNames
                        <br />
                        Checked out: @book.CheckedOutAtUtc.ToString("u")
                    </li>
                }
            </ul>
        </section>
    }
}
