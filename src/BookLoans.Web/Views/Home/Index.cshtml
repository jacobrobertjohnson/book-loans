@model HomepageViewModel
@{
    ViewData["Title"] = "Currently Checked Out";
}

<h1 class="page-title">Currently Checked Out</h1>

<div class="home-search-controls">
    <input
        id="homeSearch"
        class="home-search-input"
        type="search"
        placeholder="Search by borrower, title, author, series, or date"
        aria-label="Search checked out and available books" />
    <button id="clearHomeSearch" type="button" class="button is-hidden">Clear</button>
</div>

@if (Model.BorrowerGroups.Count == 0)
{
    <p class="muted">No books are currently checked out.</p>
}
else
{
    @foreach (BorrowerCheckoutGroupViewModel borrowerGroup in Model.BorrowerGroups)
    {
        <section data-filter-group data-borrower="@borrowerGroup.BorrowerFullName">
        <h2 class="borrower-heading">@borrowerGroup.BorrowerFullName</h2>
        <ul class="photo-grid" data-filter-grid>
            @foreach (BookLoanViewModel loan in borrowerGroup.Books)
            {
                <li class="photo-card" data-filter-tile data-borrower="@borrowerGroup.BorrowerFullName">
                    <img
                        src="@Url.Action("BookDefaultPhoto", "Admin", new { id = loan.BookId })"
                        alt="Book cover"
                        onerror="this.onerror=null;this.src='@Url.Content("~/images/book-fallback.svg")';" />
                    <div class="photo-card-meta">
                        <p class="photo-card-caption"><strong>@loan.BookTitle</strong></p>
                        @if (!string.IsNullOrEmpty(loan.BookAuthorNames))
                        {
                            <p class="muted photo-card-date">@loan.BookAuthorNames</p>
                        }
                        <p class="muted photo-card-date">Out since @loan.CheckedOutAtUtc.ToString("MMM d, yyyy")</p>
                    </div>
                </li>
            }
        </ul>
        </section>
    }
}

<section data-filter-group>
    <h2 class="borrower-heading">Available Books</h2>

@if (Model.AvailableBooks.Count == 0)
{
    <p class="muted">No books are currently available.</p>
}
else
{
    <ul class="photo-grid" data-filter-grid>
        @foreach (AvailableBookViewModel book in Model.AvailableBooks)
        {
            <li class="photo-card" data-filter-tile>
                <img
                    src="@Url.Action("BookDefaultPhoto", "Admin", new { id = book.Id })"
                    alt="Book cover"
                    onerror="this.onerror=null;this.src='@Url.Content("~/images/book-fallback.svg")';" />
                <div class="photo-card-meta">
                    @if (!string.IsNullOrEmpty(book.SeriesName))
                    {
                        <p class="photo-card-caption photo-card-series"><strong>@book.SeriesName</strong></p>
                    }
                    <p class="photo-card-caption"><strong>@book.Title</strong></p>
                    @if (!string.IsNullOrEmpty(book.AuthorNames))
                    {
                        <p class="muted photo-card-date">@book.AuthorNames</p>
                    }
                </div>
            </li>
        }
    </ul>
}
</section>

<script>
    (() => {
        const normalize = (value) => (value || "").trim().toLowerCase();

        const input = document.getElementById("homeSearch");
        const clearButton = document.getElementById("clearHomeSearch");
        const tiles = Array.from(document.querySelectorAll("[data-filter-tile]"));
        const groups = Array.from(document.querySelectorAll("[data-filter-group]"));

        if (!input || !clearButton || tiles.length === 0)
            return;

        for (const tile of tiles) {
            const borrower = tile.getAttribute("data-borrower") || "";
            tile.dataset.searchText = normalize(`${tile.textContent || ""} ${borrower}`);
        }

        const applyFilter = () => {
            const term = normalize(input.value);
            clearButton.classList.toggle("is-hidden", term.length === 0);

            for (const group of groups) {
                const groupTiles = Array.from(group.querySelectorAll("[data-filter-tile]"));
                if (groupTiles.length === 0)
                    continue;

                const groupBorrower = normalize(group.getAttribute("data-borrower") || "");
                const borrowerMatched = term.length > 0 && groupBorrower.includes(term);

                for (const tile of groupTiles) {
                    if (term.length === 0) {
                        tile.classList.remove("is-hidden");
                        continue;
                    }

                    if (borrowerMatched) {
                        tile.classList.remove("is-hidden");
                        continue;
                    }

                    const searchable = tile.dataset.searchText || "";
                    tile.classList.toggle("is-hidden", !searchable.includes(term));
                }

                const hasVisibleTile = groupTiles.some((tile) => !tile.classList.contains("is-hidden"));
                group.classList.toggle("is-hidden", !hasVisibleTile);
            }
        };

        input.addEventListener("input", applyFilter);
        clearButton.addEventListener("click", () => {
            input.value = "";
            applyFilter();
            input.focus();
        });

        applyFilter();
    })();
</script>
