@model BooksIndexViewModel
@{
    ViewData["Title"] = "Manage Books";
}

@if (TempData["BooksError"] is string booksError)
{
    <p class="message-error">@booksError</p>
}

<div class="card table-wrap">
    <div class="card-header">
        <h1 class="page-title">Manage Books</h1>
        <a class="button button-primary" asp-action="CreateBook">Add Book</a>
        <a class="button" asp-action="BulkImportBooks">Import Books</a>
        <a class="button" asp-action="BulkExportBooks">Export Books</a>
    </div>
    @if (Model.Books.Count == 0)
    {
        <p class="muted">No books have been added yet.</p>
    }
    else
    {
    <table>
        <thead>
            <tr>
                <th></th>
                <th>Title</th>
                <th>Author</th>
                <th>Checked Out</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
        @foreach (BookListItemViewModel book in Model.Books)
        {
            <tr>
                <td class="thumb-cell">
                    <img
                        src="@Url.Action("BookDefaultPhoto", "Admin", new { id = book.Id })"
                        alt="Book cover"
                        class="media-thumb"
                        onerror="this.onerror=null;this.src='@Url.Content("~/images/book-fallback.svg")';" />
                </td>
                <td>
                    @if (!string.IsNullOrEmpty(book.SeriesName))
                    {
                        <p class="book-series"><strong>@book.SeriesName</strong></p>
                    }
                    <a asp-action="EditBook" asp-route-id="@book.Id">@book.Title</a>
                </td>
                <td>
                    @for (int i = 0; i < book.Authors.Count; i++)
                    {
                        <a asp-action="EditAuthor" asp-route-id="@book.Authors[i].Id">@book.Authors[i].Name</a>@(i < book.Authors.Count - 1 ? ", " : string.Empty)
                    }
                    @if (book.Authors.Count == 0)
                    {
                        <text>(unknown)</text>
                    }
                </td>
                <td>
                    @if (book.CurrentBorrowerName is not null && book.CurrentBorrowerId is not null)
                    {
                        <a asp-action="EditBorrower" asp-route-id="@book.CurrentBorrowerId">@book.CurrentBorrowerName</a>
                        <br /><small class="muted">@book.CurrentCheckedOutAtUtc?.ToString("u")</small>
                    }
                </td>
                <td>
                    <form asp-action="DeleteBook" asp-route-id="@book.Id" method="post" class="inline">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="button-danger">Delete</button>
                    </form>
                </td>
            </tr>
        }
        </tbody>
    </table>
    }
</div>
