@model ConditionFormViewModel
@{
    ViewData["Title"] = "Create Condition";
}

<div class="page-title-row">
    <a class="back-arrow" asp-action="Conditions" title="Back to Manage Conditions">&#8592;</a>
    <h1 class="page-title">Create Condition</h1>
</div>

<form asp-action="CreateCondition" method="post" class="form-shell stack">
    @Html.AntiForgeryToken()
    <div asp-validation-summary="ModelOnly" class="message-error"></div>

    <h2>Condition Details</h2>

    <div class="field">
        <label asp-for="Name"></label>
        <input asp-for="Name" />
        <span asp-validation-for="Name"></span>
    </div>

    <div class="actions-row">
        <button type="submit" class="button-primary">Save</button>
    </div>
</form>
