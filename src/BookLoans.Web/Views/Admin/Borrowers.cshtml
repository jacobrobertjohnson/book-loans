@model BorrowersIndexViewModel
@{
    ViewData["Title"] = "Manage Borrowers";
}

@if (TempData["BorrowersError"] is string borrowersError)
{
    <p class="message-error">@borrowersError</p>
}

<div class="card table-wrap">
    <div class="card-header">
        <h1 class="page-title">Manage Borrowers</h1>
        <a class="button button-primary" asp-action="CreateBorrower">Add Borrower</a>
    </div>
    @if (Model.Borrowers.Count == 0)
    {
        <p class="muted">No borrowers have been added yet.</p>
    }
    else
    {
    <table>
        <thead>
            <tr>
                <th>Name</th>
                <th>Current Books</th>
                <th>Loan History</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
        @foreach (BorrowerListItemViewModel borrower in Model.Borrowers)
        {
            <tr>
                <td><a asp-action="EditBorrower" asp-route-id="@borrower.Id">@borrower.FirstName @borrower.LastName</a></td>
                <td>@borrower.CurrentBookCount</td>
                <td>@borrower.LoanCount</td>
                <td>
                    <form asp-action="DeleteBorrower" asp-route-id="@borrower.Id" method="post" class="inline">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="button-danger">Delete</button>
                    </form>
                </td>
            </tr>
        }
        </tbody>
    </table>
    }
</div>
