{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Launch BookLoans.Web",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "build-solution",
      "program": "${workspaceFolder}/src/BookLoans.Web/bin/Debug/net10.0/BookLoans.Web.dll",
      "args": [],
      "cwd": "${workspaceFolder}/src/BookLoans.Web",
      "stopAtEntry": false,
      "env": {
        "ASPNETCORE_ENVIRONMENT": "Development"
      },
      "serverReadyAction": {
        "action": "openExternally",
        "pattern": "\\bNow listening on:\\s+(https?://\\S+)"
      }
    }
  ]
}
